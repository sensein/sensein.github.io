---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Container from "~/components/Container.astro";
import Hero from "~/components/Hero.astro";
import SectionHeading from "~/components/SectionHeading.astro";
import { withBase } from "~/lib/url";

const searchAction = withBase("/search/");
---
<BaseLayout>
  <Hero />

  <Container size="wide" class="py-16">
    <div class="grid lg:grid-cols-[2fr_1fr] gap-12 lg:gap-16 items-start">
      <section>
        <SectionHeading
          eyebrow="Explore"
          title="Search the group"
          description="Find people, projects, and publications in one place."
        />
        <form
          action={searchAction}
          method="get"
          class="rounded-lg border border-(--color-border) bg-(--color-surface)/40 p-4"
          role="search"
        >
          <label class="flex items-stretch gap-2">
            <span class="sr-only">Search query</span>
            <span
              aria-hidden="true"
              class="inline-flex items-center px-3 rounded-md bg-(--color-canvas) border border-(--color-border) text-(--color-ink-faint)"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="7" />
                <line x1="21" y1="21" x2="16.65" y2="16.65" />
              </svg>
            </span>
            <input
              type="search"
              name="q"
              placeholder="Search people, projects, publications…"
              autocomplete="off"
              class="flex-1 rounded-md border border-(--color-border) bg-(--color-canvas) px-4 py-3 text-base text-(--color-ink) placeholder:text-(--color-ink-faint) focus:outline-none focus:border-(--color-accent)"
            />
            <button
              type="submit"
              class="rounded-md bg-(--color-accent) hover:bg-(--color-accent-strong) text-white px-5 py-3 text-sm font-medium transition-colors"
            >
              Search
            </button>
          </label>
          <div class="mt-3 flex flex-wrap gap-2 text-xs text-(--color-ink-muted)">
            <span class="text-(--color-ink-faint)">Try:</span>
            <a href={`${searchAction}?q=dandi`} class="px-2 py-0.5 rounded-full border border-(--color-border) hover:border-(--color-accent) hover:text-(--color-accent) transition-colors">dandi</a>
            <a href={`${searchAction}?q=stutter`} class="px-2 py-0.5 rounded-full border border-(--color-border) hover:border-(--color-accent) hover:text-(--color-accent) transition-colors">stutter</a>
            <a href={`${searchAction}?q=reproducibility`} class="px-2 py-0.5 rounded-full border border-(--color-border) hover:border-(--color-accent) hover:text-(--color-accent) transition-colors">reproducibility</a>
            <a href={`${searchAction}?q=satra`} class="px-2 py-0.5 rounded-full border border-(--color-border) hover:border-(--color-accent) hover:text-(--color-accent) transition-colors">satra</a>
            <a href={`${searchAction}?q=BICAN`} class="px-2 py-0.5 rounded-full border border-(--color-border) hover:border-(--color-accent) hover:text-(--color-accent) transition-colors">BICAN</a>
          </div>
        </form>
      </section>

      <aside class="lg:sticky lg:top-24 self-start space-y-3 text-sm">
        <SectionHeading eyebrow="Sections" title="Where to go" />
        <ul class="space-y-2">
          <li>
            <a href={withBase("/research")} class="text-(--color-accent) hover:text-(--color-accent-strong) underline-offset-3 hover:underline">
              Research projects →
            </a>
          </li>
          <li>
            <a href={withBase("/publications")} class="text-(--color-accent) hover:text-(--color-accent-strong) underline-offset-3 hover:underline">
              Publications →
            </a>
          </li>
          <li>
            <a href={withBase("/team")} class="text-(--color-accent) hover:text-(--color-accent-strong) underline-offset-3 hover:underline">
              The team →
            </a>
          </li>
          <li>
            <a href={withBase("/news")} class="text-(--color-accent) hover:text-(--color-accent-strong) underline-offset-3 hover:underline">
              News archive →
            </a>
          </li>
          <li>
            <a href={withBase("/openings")} class="text-(--color-accent) hover:text-(--color-accent-strong) underline-offset-3 hover:underline">
              Openings →
            </a>
          </li>
        </ul>
      </aside>
    </div>
  </Container>
</BaseLayout>
