---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Container from "~/components/Container.astro";
import Hero from "~/components/Hero.astro";
import NewsList from "~/components/NewsList.astro";
import SectionHeading from "~/components/SectionHeading.astro";
import { withBase } from "~/lib/url";
---
<BaseLayout>
  <Hero />

  <Container size="wide" class="py-20">
    <div class="grid lg:grid-cols-[2fr_1fr] gap-12 lg:gap-16">
      <section>
        <SectionHeading eyebrow="Latest" title="News" />
        <NewsList limit={8} />
        <p class="mt-6">
          <a
            href={withBase("/news")}
            class="text-sm font-medium text-(--color-accent) hover:text-(--color-accent-strong) underline-offset-3 hover:underline"
          >
            All news →
          </a>
        </p>
      </section>

      <aside class="lg:sticky lg:top-24 self-start space-y-3 text-sm">
        <SectionHeading eyebrow="Explore" title="Where to go" />
        <ul class="space-y-2">
          <li>
            <a href={withBase("/research")} class="text-(--color-accent) hover:text-(--color-accent-strong) underline-offset-3 hover:underline">
              Research projects →
            </a>
          </li>
          <li>
            <a href={withBase("/publications")} class="text-(--color-accent) hover:text-(--color-accent-strong) underline-offset-3 hover:underline">
              Publications →
            </a>
          </li>
          <li>
            <a href={withBase("/team")} class="text-(--color-accent) hover:text-(--color-accent-strong) underline-offset-3 hover:underline">
              The team →
            </a>
          </li>
          <li>
            <a href={withBase("/openings")} class="text-(--color-accent) hover:text-(--color-accent-strong) underline-offset-3 hover:underline">
              Openings →
            </a>
          </li>
        </ul>
      </aside>
    </div>
  </Container>
</BaseLayout>
