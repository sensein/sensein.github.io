---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Container from "~/components/Container.astro";
import SectionHeading from "~/components/SectionHeading.astro";
import PublicationItem from "~/components/PublicationItem.astro";
import { publications } from "~/lib/data";
import { withBase } from "~/lib/url";
import yaml from "js-yaml";

const pageRaw = (await import("~/data/publications_page.yml?raw")).default as string;
const page = yaml.load(pageRaw) as {
  summary: string;
  keywords: string[];
  topics: { label: string; tag?: string; description: string; example_count: number }[];
};

const all = publications().sort((a, b) => (b.year ?? 0) - (a.year ?? 0));
const totalCount = all.length;

const years = Array.from(new Set(all.map((p) => p.year))).sort((a, b) => b - a);
const types = Array.from(new Set(all.map((p) => p.type))).sort();
const categories = Array.from(new Set(all.map((p) => p.category).filter(Boolean))).sort();
const topicTags = (() => {
  const c = new Map<string, number>();
  for (const p of all) for (const t of p.topics ?? []) c.set(t, (c.get(t) ?? 0) + 1);
  return [...c.entries()].sort((a, b) => b[1] - a[1]).map(([k, v]) => ({ tag: k, count: v }));
})();

// Group publications by year for the rendered list.
const byYear = new Map<number, typeof all>();
for (const p of all) {
  if (!byYear.has(p.year)) byYear.set(p.year, []);
  byYear.get(p.year)!.push(p);
}
const yearGroups = [...byYear.entries()].sort((a, b) => b[0] - a[0]);
---
<BaseLayout title="Publications" description={page.summary}>
  <Container size="wide" class="pt-14 pb-6">
    <div class="grid lg:grid-cols-[1.7fr_1fr] gap-10 items-center">
      <div>
        <p class="text-xs uppercase tracking-[0.18em] text-(--color-accent) font-medium">
          Publications · {totalCount} papers and preprints
        </p>
        <p class="mt-5 text-lg text-(--color-ink-muted) leading-relaxed max-w-3xl">
          {page.summary}
        </p>
        <p class="mt-3 text-sm text-(--color-ink-muted)">
          Also see
          <a
            href="https://scholar.google.com/citations?user=QnYCqUsAAAAJ&hl=en"
            target="_blank"
            rel="noopener"
            class="text-(--color-accent) hover:text-(--color-accent-strong) underline-offset-3 hover:underline"
          >Google Scholar</a> for the continually-updated index.
        </p>
      </div>
      <figure class="text-(--color-ink-muted)">
        <img
          src={withBase("/images/publications-hero.svg")}
          alt=""
          class="w-full max-w-md"
        />
      </figure>
    </div>
  </Container>

  <!-- Topic areas summary; cards are clickable filters -->
  <Container size="wide" class="py-6">
    <SectionHeading title="Topic areas" description="Click a topic to filter the list below." />
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3 text-sm">
      {page.topics.map((t) => (
        <button
          type="button"
          data-topic-card
          data-topic-tag={t.tag ?? ""}
          class="text-left rounded-lg border border-(--color-border) bg-(--color-canvas) p-4 hover:border-(--color-accent) hover:shadow-sm transition-all"
        >
          <p class="font-medium text-(--color-ink)">{t.label}</p>
          <p class="mt-1 text-xs text-(--color-ink-muted) leading-snug">{t.description}</p>
          <p class="mt-2 text-[11px] text-(--color-ink-faint) font-mono">
            {t.example_count} papers
            {t.tag && <span class="ml-1">· tag <code>{t.tag}</code></span>}
          </p>
        </button>
      ))}
    </div>
  </Container>

  <!-- Filters -->
  <Container size="wide" class="pt-10 pb-2">
    <SectionHeading id="full-list" title="All publications" description="Filter by year, type, category, or topic. Filters combine (AND)." />
    <div class="rounded-lg border border-(--color-border) bg-(--color-surface)/40 p-4 text-sm" data-pub-filters>
      <div class="grid sm:grid-cols-4 gap-4">
        <label class="flex flex-col gap-1">
          <span class="text-[11px] uppercase tracking-wider text-(--color-ink-faint)">Year</span>
          <select data-filter="year" class="rounded-md border border-(--color-border) bg-(--color-canvas) px-2 py-1.5 text-(--color-ink)">
            <option value="">All ({totalCount})</option>
            {years.map((y) => <option value={y}>{y}</option>)}
          </select>
        </label>
        <label class="flex flex-col gap-1">
          <span class="text-[11px] uppercase tracking-wider text-(--color-ink-faint)">Type</span>
          <select data-filter="type" class="rounded-md border border-(--color-border) bg-(--color-canvas) px-2 py-1.5 text-(--color-ink)">
            <option value="">All</option>
            {types.map((t) => <option value={t}>{t}</option>)}
          </select>
        </label>
        <label class="flex flex-col gap-1">
          <span class="text-[11px] uppercase tracking-wider text-(--color-ink-faint)">Category</span>
          <select data-filter="category" class="rounded-md border border-(--color-border) bg-(--color-canvas) px-2 py-1.5 text-(--color-ink)">
            <option value="">All</option>
            {categories.map((c) => <option value={c}>{c}</option>)}
          </select>
        </label>
        <label class="flex flex-col gap-1">
          <span class="text-[11px] uppercase tracking-wider text-(--color-ink-faint)">Topic</span>
          <select data-filter="topic" class="rounded-md border border-(--color-border) bg-(--color-canvas) px-2 py-1.5 text-(--color-ink)">
            <option value="">All</option>
            {topicTags.map((t) => <option value={t.tag}>{t.tag} ({t.count})</option>)}
          </select>
        </label>
      </div>
      <div class="mt-3 flex items-center justify-between text-xs text-(--color-ink-faint)">
        <span><span data-pub-count>{totalCount}</span> of {totalCount} papers shown</span>
        <button type="button" data-reset class="text-(--color-accent) hover:text-(--color-accent-strong) underline-offset-3 hover:underline">Reset filters</button>
      </div>
    </div>
  </Container>

  <!-- List -->
  <Container size="wide" class="py-6">
    {yearGroups.map(([year, items]) => (
      <section data-year-group={year} class="mt-8">
        <h2 class="text-xs uppercase tracking-wider text-(--color-ink-faint) py-2 border-b border-(--color-border) sticky top-16 bg-(--color-canvas)/95 backdrop-blur-sm">
          {year}  ·  {items.length} {items.length === 1 ? "paper" : "papers"}
        </h2>
        <ul>
          {items.map((p) => (
            <li
              data-pub
              data-type={p.type}
              data-category={p.category}
              data-topics={(p.topics ?? []).join(",")}
              data-year={p.year}
            >
              <PublicationItem pub={p} />
            </li>
          ))}
        </ul>
      </section>
    ))}
  </Container>
</BaseLayout>

<script>
  const root = document.querySelector<HTMLElement>("[data-pub-filters]");
  if (root) {
    const selects = Array.from(root.querySelectorAll<HTMLSelectElement>("select[data-filter]"));
    const reset = root.querySelector<HTMLButtonElement>("[data-reset]");
    const counter = root.querySelector<HTMLElement>("[data-pub-count]");
    const items = Array.from(document.querySelectorAll<HTMLElement>("[data-pub]"));
    const groups = Array.from(document.querySelectorAll<HTMLElement>("[data-year-group]"));

    function applyFilters() {
      const filters: Record<string, string> = {};
      for (const s of selects) if (s.value) filters[s.dataset.filter!] = s.value;
      let visible = 0;
      for (const item of items) {
        let ok = true;
        if (filters.year && item.dataset.year !== filters.year) ok = false;
        if (filters.type && item.dataset.type !== filters.type) ok = false;
        if (filters.category && item.dataset.category !== filters.category) ok = false;
        if (filters.topic) {
          const topics = (item.dataset.topics ?? "").split(",");
          if (!topics.includes(filters.topic)) ok = false;
        }
        item.style.display = ok ? "" : "none";
        if (ok) visible++;
      }
      for (const g of groups) {
        const hasVisible = Array.from(g.querySelectorAll<HTMLElement>("[data-pub]")).some(
          (el) => el.style.display !== "none",
        );
        g.style.display = hasVisible ? "" : "none";
      }
      if (counter) counter.textContent = String(visible);
    }
    selects.forEach((s) => s.addEventListener("change", applyFilters));
    reset?.addEventListener("click", () => {
      selects.forEach((s) => (s.value = ""));
      applyFilters();
    });

    // Topic-area cards act as quick filter shortcuts.
    const topicSelect = selects.find((s) => s.dataset.filter === "topic");
    document.querySelectorAll<HTMLButtonElement>("[data-topic-card]").forEach((card) => {
      card.addEventListener("click", () => {
        const tag = card.dataset.topicTag ?? "";
        if (!tag || !topicSelect) return;
        // Toggle off if same tag is already applied.
        if (topicSelect.value === tag) {
          topicSelect.value = "";
        } else {
          topicSelect.value = tag;
        }
        applyFilters();
        document.getElementById("full-list")?.scrollIntoView({ behavior: "smooth", block: "start" });
      });
    });
  }
</script>
