---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Container from "~/components/Container.astro";
import {
  publications,
  projects,
  teamMembers,
  alumniMembers,
  students,
} from "~/lib/data";
import { withBase } from "~/lib/url";

// Counts only — the actual search index + embeddings live as static files in
// public/, generated by scripts/build-search-embeddings.mjs (prebuild step).
const peopleCount = teamMembers().length + students().length + alumniMembers().length;
const projectCount = projects().length;
const pubCount = publications().length;
---
<BaseLayout title="Search" description="Semantic search across people, projects, and publications.">
  <Container size="wide" class="pt-14 pb-6">
    <p class="text-xs uppercase tracking-[0.18em] text-(--color-accent) font-medium">Search</p>
    <h1 class="mt-4 font-serif text-4xl md:text-5xl font-semibold tracking-tight text-(--color-ink) leading-[1.05]">
      Find anything on the site
    </h1>
    <p class="mt-5 text-lg text-(--color-ink-muted) leading-relaxed max-w-3xl">
      Semantic search across people ({peopleCount}), projects ({projectCount}),
      and publications ({pubCount}). Keyword matching ranks results
      instantly; an on-device MiniLM model (all-MiniLM-L6-v2 via
      transformers.js) loads in the background and adds semantic ranking
      once it's ready — your queries don't leave the browser.
    </p>
  </Container>

  <Container size="wide" class="py-6">
    <div class="rounded-lg border border-(--color-border) bg-(--color-surface)/40 p-4">
      <label class="block">
        <span class="sr-only">Search query</span>
        <input
          type="search"
          autocomplete="off"
          placeholder="Search…"
          data-search-input
          class="w-full rounded-md border border-(--color-border) bg-(--color-canvas) px-4 py-3 text-lg text-(--color-ink) placeholder:text-(--color-ink-faint) focus:outline-none focus:border-(--color-accent)"
          autofocus
        />
      </label>
      <div class="mt-3 flex flex-wrap items-center gap-2 text-xs" data-kind-filters>
        <button type="button" data-kind="all" class="px-3 py-1.5 rounded-full border border-(--color-accent) bg-(--color-accent-soft) text-(--color-accent-strong) font-medium">
          All
        </button>
        <button type="button" data-kind="person" class="px-3 py-1.5 rounded-full border border-(--color-border) text-(--color-ink-muted) hover:border-(--color-border-strong)">
          People
        </button>
        <button type="button" data-kind="project" class="px-3 py-1.5 rounded-full border border-(--color-border) text-(--color-ink-muted) hover:border-(--color-border-strong)">
          Projects
        </button>
        <button type="button" data-kind="publication" class="px-3 py-1.5 rounded-full border border-(--color-border) text-(--color-ink-muted) hover:border-(--color-border-strong)">
          Publications
        </button>
        <span class="ml-auto inline-flex items-center gap-1.5 text-(--color-ink-faint)" data-semantic-status>
          <span data-semantic-dot class="inline-block w-1.5 h-1.5 rounded-full bg-(--color-border-strong)"></span>
          <span data-semantic-label>semantic: not loaded</span>
        </span>
      </div>
      <p class="mt-3 text-xs text-(--color-ink-faint)" data-result-count></p>
    </div>
  </Container>

  <Container size="wide" class="pb-20">
    <ol data-results class="divide-y divide-(--color-border) border-y border-(--color-border)"></ol>
    <p data-empty class="hidden py-12 text-center text-(--color-ink-faint)">
      No matches. Try a shorter or different query.
    </p>
  </Container>

  <script define:vars={{ INDEX_URL: withBase("/search-index.json"), VECTORS_URL: withBase("/search-vectors.bin") }}>
    // Hybrid keyword + MiniLM search. Records + embeddings are static files
    // built by scripts/build-search-embeddings.mjs.
    type Record = {
      k: "person" | "project" | "publication";
      t: string;
      b: string;
      h: string;
      y: number | null;
      g: string;
      r: string | null;
      s: string | null;
    };

    const input = document.querySelector<HTMLInputElement>("[data-search-input]");
    const resultsEl = document.querySelector<HTMLOListElement>("[data-results]");
    const emptyEl = document.querySelector<HTMLElement>("[data-empty]");
    const countEl = document.querySelector<HTMLElement>("[data-result-count]");
    const filterBtns = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-kind-filters] button"));
    const semDot = document.querySelector<HTMLElement>("[data-semantic-dot]");
    const semLabel = document.querySelector<HTMLElement>("[data-semantic-label]");
    let activeKind = "all";

    let records: Record[] = [];
    let vectors: Float32Array | null = null; // length = records.length * dim
    let dim = 0;
    let extractor: any = null;
    let extractorLoadStarted = false;

    function escapeHtml(s: string) {
      return s.replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]!));
    }

    // Convert IEEE 754 float16 (Uint16) → float32. Standard formula.
    function f16ToF32(h: number): number {
      const sign = (h & 0x8000) >> 15;
      const exp = (h & 0x7c00) >> 10;
      const mant = h & 0x03ff;
      if (exp === 0) return (sign ? -1 : 1) * Math.pow(2, -14) * (mant / 1024);
      if (exp === 0x1f) return mant ? NaN : (sign ? -Infinity : Infinity);
      return (sign ? -1 : 1) * Math.pow(2, exp - 15) * (1 + mant / 1024);
    }

    function setSemanticStatus(state: "off" | "loading" | "ready" | "error", label?: string) {
      if (!semDot || !semLabel) return;
      const map = {
        off: "bg-(--color-border-strong)",
        loading: "bg-(--color-accent)",
        ready: "bg-emerald-500",
        error: "bg-red-500",
      } as const;
      semDot.className = `inline-block w-1.5 h-1.5 rounded-full ${map[state]}`;
      if (state === "loading") semDot.classList.add("animate-pulse");
      else semDot.classList.remove("animate-pulse");
      semLabel.textContent = label ?? `semantic: ${state === "ready" ? "ready" : state === "loading" ? "loading…" : state === "error" ? "unavailable" : "not loaded"}`;
    }

    async function loadIndex() {
      const res = await fetch(INDEX_URL);
      if (!res.ok) throw new Error(`index ${res.status}`);
      records = await res.json();
    }

    async function loadVectors() {
      const res = await fetch(VECTORS_URL);
      if (!res.ok) throw new Error(`vectors ${res.status}`);
      const buf = await res.arrayBuffer();
      const view = new DataView(buf);
      const magic = String.fromCharCode(view.getUint8(0), view.getUint8(1), view.getUint8(2), view.getUint8(3));
      if (magic !== "SVEC") throw new Error("bad magic");
      const count = view.getUint32(4, true);
      dim = view.getUint32(8, true);
      const dtype = view.getUint32(12, true);
      if (dtype !== 2) throw new Error(`unsupported dtype ${dtype}`);
      const u16 = new Uint16Array(buf, 16, count * dim);
      vectors = new Float32Array(u16.length);
      for (let i = 0; i < u16.length; i++) vectors[i] = f16ToF32(u16[i]);
    }

    async function ensureExtractor() {
      if (extractor) return extractor;
      if (extractorLoadStarted) return null; // still loading
      extractorLoadStarted = true;
      setSemanticStatus("loading", "semantic: loading model…");
      try {
        const mod = await import("@xenova/transformers");
        mod.env.allowLocalModels = false;
        extractor = await mod.pipeline("feature-extraction", "Xenova/all-MiniLM-L6-v2");
        setSemanticStatus("ready");
        return extractor;
      } catch (e) {
        console.error("transformers.js failed", e);
        setSemanticStatus("error");
        return null;
      }
    }

    async function embedQuery(q: string): Promise<Float32Array | null> {
      const ex = await ensureExtractor();
      if (!ex) return null;
      const out = await ex(q, { pooling: "mean", normalize: true });
      return out.data as Float32Array;
    }

    function keywordScore(rec: Record, qTokens: string[]): number {
      if (qTokens.length === 0) return 0;
      const t = rec.t.toLowerCase();
      const b = rec.b.toLowerCase();
      const g = rec.g;
      let s = 0;
      for (const q of qTokens) {
        if (t === q) s += 100;
        else if (t.startsWith(q + " ") || t.startsWith(q + "-")) s += 50;
        else if (t.includes(q)) s += 25;
        if (g.includes(q)) s += 15;
        if (b.includes(q)) s += 5;
      }
      return s;
    }

    function cosineSim(qVec: Float32Array, idx: number): number {
      if (!vectors) return 0;
      const off = idx * dim;
      let s = 0;
      for (let i = 0; i < dim; i++) s += qVec[i] * vectors[off + i];
      return s; // both unit-normed
    }

    function kindLabel(k: string): string {
      return k === "person" ? "Person" : k === "project" ? "Project" : "Publication";
    }

    let renderToken = 0;
    let lastQuery = "";

    async function render() {
      const myToken = ++renderToken;
      const q = (input?.value ?? "").trim();
      const qLower = q.toLowerCase();
      const qTokens = qLower.split(/\s+/).filter(Boolean);
      let pool = records.map((r, idx) => ({ r, idx }));
      if (activeKind !== "all") pool = pool.filter(({ r }) => r.k === activeKind);

      let hits: { r: Record; idx: number; s: number }[];
      if (qTokens.length > 0) {
        // Initial pass: keyword scores so results show instantly.
        hits = pool
          .map(({ r, idx }) => ({ r, idx, s: keywordScore(r, qTokens) }))
          .filter((x) => x.s > 0)
          .sort((a, b) => b.s - a.s);

        // If there's no keyword hit, still show the full pool so semantic
        // can rank it later.
        if (hits.length === 0) hits = pool.map(({ r, idx }) => ({ r, idx, s: 0 }));
      } else {
        hits = pool.map(({ r, idx }) => ({ r, idx, s: 0 }));
        hits.sort((a, b) => a.r.k.localeCompare(b.r.k) || a.r.t.localeCompare(b.r.t));
        hits = hits.slice(0, 50);
      }

      paint(hits, q);

      // Semantic re-rank (async). Only if we have a query and vectors loaded.
      if (qTokens.length === 0 || !vectors) return;
      if (q === lastQuery) return;
      lastQuery = q;
      const qVec = await embedQuery(q);
      if (myToken !== renderToken) return; // newer query in flight
      if (!qVec) return;

      // Blend: keyword (0..100+) normalised by max kw score, weighted 0.4;
      // cosine (0..1) weighted 0.6.
      const maxKw = Math.max(1, ...hits.map((h) => h.s));
      const blended = pool.map(({ r, idx }) => {
        const kw = keywordScore(r, qTokens) / maxKw;
        const sem = cosineSim(qVec, idx);
        return { r, idx, s: 0.4 * kw + 0.6 * sem };
      });
      blended.sort((a, b) => b.s - a.s);
      // Filter out near-zero matches.
      const filtered = blended.filter((x) => x.s > 0.15).slice(0, 100);
      paint(filtered, q);
    }

    function paint(hits: { r: Record; s: number }[], q: string) {
      if (hits.length === 0) {
        resultsEl!.innerHTML = "";
        emptyEl!.classList.remove("hidden");
        countEl!.textContent = "No results";
        return;
      }
      emptyEl!.classList.add("hidden");
      countEl!.textContent = q
        ? `${hits.length} result${hits.length === 1 ? "" : "s"} for "${q}"`
        : `Showing ${hits.length} item${hits.length === 1 ? "" : "s"} (start typing to filter)`;
      resultsEl!.innerHTML = hits
        .slice(0, 200)
        .map(({ r }) => {
          const meta = [
            kindLabel(r.k),
            r.y != null ? r.y.toString() : null,
            r.s ? (r.s === "former" ? "past" : r.s) : null,
            r.r ? r.r : null,
          ]
            .filter(Boolean)
            .join("  ·  ");
          return `<li class="py-4">
  <a href="${escapeHtml(r.h)}" class="block group">
    <p class="text-[11px] uppercase tracking-wider text-(--color-ink-faint)">${escapeHtml(meta)}</p>
    <p class="mt-1 text-(--color-ink) group-hover:text-(--color-accent) transition-colors leading-snug">${escapeHtml(r.t)}</p>
    ${r.b.trim() ? `<p class="mt-1 text-xs text-(--color-ink-muted) leading-snug line-clamp-2">${escapeHtml(r.b.slice(0, 200))}</p>` : ""}
  </a>
</li>`;
        })
        .join("");
    }

    input?.addEventListener("input", () => {
      lastQuery = ""; // allow re-ranking
      render();
    });
    filterBtns.forEach((btn) =>
      btn.addEventListener("click", () => {
        activeKind = btn.dataset.kind!;
        filterBtns.forEach((b) => {
          if (b === btn) {
            b.classList.add("border-(--color-accent)", "bg-(--color-accent-soft)", "text-(--color-accent-strong)", "font-medium");
            b.classList.remove("border-(--color-border)", "text-(--color-ink-muted)", "hover:border-(--color-border-strong)");
          } else {
            b.classList.remove("border-(--color-accent)", "bg-(--color-accent-soft)", "text-(--color-accent-strong)", "font-medium");
            b.classList.add("border-(--color-border)", "text-(--color-ink-muted)", "hover:border-(--color-border-strong)");
          }
        });
        lastQuery = "";
        render();
      }),
    );

    // Pre-fill from ?q= and (optional) ?kind=
    const url = new URL(window.location.href);
    const initialQ = url.searchParams.get("q");
    if (initialQ && input) input.value = initialQ;
    const initialKind = url.searchParams.get("kind");
    if (initialKind && filterBtns.some((b) => b.dataset.kind === initialKind)) {
      activeKind = initialKind;
      filterBtns.forEach((b) => {
        const on = b.dataset.kind === initialKind;
        b.classList.toggle("bg-(--color-accent-soft)", on);
        b.classList.toggle("text-(--color-accent-strong)", on);
        b.classList.toggle("border-(--color-accent)", on);
        b.classList.toggle("font-medium", on);
        b.classList.toggle("text-(--color-ink-muted)", !on);
        b.classList.toggle("border-(--color-border)", !on);
      });
    }

    // Boot: load the index, render, then load vectors + model in background.
    (async () => {
      try {
        await loadIndex();
        render();
        try {
          await loadVectors();
          setSemanticStatus("loading", "semantic: warming up");
          // Kick off the extractor download too — doesn't block keyword search.
          ensureExtractor().then(() => {
            // Re-render so a typed query gets re-ranked.
            lastQuery = "";
            render();
          });
        } catch (e) {
          console.warn("vector load failed", e);
          setSemanticStatus("error", "semantic: unavailable");
        }
      } catch (e) {
        console.error("search failed to initialise", e);
        countEl!.textContent = "Search failed to load.";
      }
    })();
  </script>
</BaseLayout>
