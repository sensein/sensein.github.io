---
import PageLayout from "~/layouts/PageLayout.astro";
import SectionHeading from "~/components/SectionHeading.astro";
import MemberTile from "~/components/MemberTile.astro";
import { teamMembers, students, alumniMembers } from "~/lib/data";

const members = teamMembers();
const studentList = students();
const alumni = alumniMembers();
---
<PageLayout
  eyebrow="People"
  title="The team"
  size="wide"
  lede="The researchers, engineers, students, and alumni who make this work happen. Click a tile to expand details."
>
  <section>
    <SectionHeading id="members" eyebrow="Members" title="Current members" />
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {members.map((m) => <MemberTile member={m} />)}
    </div>
  </section>

  {studentList.length > 0 && (
    <section class="mt-20">
      <SectionHeading id="students" eyebrow="Students" title="Students" />
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {studentList.map((m) => <MemberTile member={m} />)}
      </div>
    </section>
  )}

  <section class="mt-20">
    <SectionHeading
      id="alumni"
      eyebrow="Past members"
      title="Alumni"
      description="Past members of the group and their roles while with us."
    />
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {alumni.map((m) => (
        <MemberTile member={m} showEducation={false} showDuration />
      ))}
    </div>
  </section>
</PageLayout>
