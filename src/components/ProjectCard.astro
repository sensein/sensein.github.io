---
import type { Project } from "~/lib/data";
import { personHref } from "~/lib/data";
import { normalizeImage } from "~/lib/images";
import { withBase } from "~/lib/url";

interface Props {
  project: Project;
  featured?: boolean;
}
const { project } = Astro.props;
const image = project.image ? normalizeImage(project.image) : null;

const primaryLink =
  project.links?.find((l) => l.url)?.url ?? project.link?.url ?? null;

const contributors = [
  ...(project.contributors?.current ?? []).map((n) => ({ name: n, kind: "current" as const })),
  ...(project.contributors?.former ?? []).map((n) => ({ name: n, kind: "former" as const })),
];

function linkify(href: string): string {
  return /^https?:\/\//i.test(href) ? href : withBase(href);
}
---
<article
  class="group flex flex-col rounded-lg border border-(--color-border) bg-(--color-canvas) overflow-hidden hover:border-(--color-border-strong) hover:shadow-sm transition-all"
>
  {image && (
    <a
      href={primaryLink ? linkify(primaryLink) : "#"}
      class="block aspect-[16/9] bg-(--color-surface) overflow-hidden"
      target={primaryLink?.startsWith("http") ? "_blank" : undefined}
      rel={primaryLink?.startsWith("http") ? "noopener" : undefined}
    >
      <img
        src={image}
        alt={project.title}
        loading="lazy"
        class="w-full h-full object-contain bg-(--color-surface) group-hover:scale-[1.02] transition-transform duration-500"
      />
    </a>
  )}
  <div class="p-5 flex-1 flex flex-col">
    <div class="flex items-start justify-between gap-3">
      <h3 class="font-serif text-lg font-semibold text-(--color-ink) leading-snug">
        {project.title}
      </h3>
      {project.status === "former" && (
        <span class="shrink-0 text-[10px] uppercase tracking-wider px-1.5 py-0.5 rounded border border-(--color-border) text-(--color-ink-faint)">
          past
        </span>
      )}
    </div>

    {project.funder && (
      <p class="mt-1 text-xs text-(--color-ink-faint) font-mono">
        {project.funder}
      </p>
    )}

    {project.description && (
      <p class="mt-3 text-sm text-(--color-ink-muted) leading-relaxed">
        {project.description}
      </p>
    )}

    {contributors.length > 0 && (
      <p class="mt-3 text-xs text-(--color-ink-muted) leading-relaxed">
        <span class="text-(--color-ink-faint)">People: </span>
        {contributors.map((c, i) => {
          const href = personHref(c.name);
          const label = c.kind === "former" ? `${c.name}*` : c.name;
          return (
            <>
              {href ? (
                <a
                  href={withBase(href)}
                  class="text-(--color-ink) hover:text-(--color-accent) underline-offset-3 hover:underline"
                >
                  {label}
                </a>
              ) : (
                <span>{label}</span>
              )}
              {i < contributors.length - 1 && <span>, </span>}
            </>
          );
        })}
      </p>
    )}

    {project.themes && project.themes.length > 0 && (
      <ul class="mt-3 flex flex-wrap gap-1.5">
        {project.themes.map((t) => (
          <li class="text-[11px] px-1.5 py-0.5 rounded border border-(--color-border) text-(--color-ink-muted) bg-(--color-surface)/40">
            {t}
          </li>
        ))}
      </ul>
    )}

    {project.links && project.links.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-x-4 gap-y-1.5 text-sm">
        {project.links.map((l) =>
          l.url ? (
            <a
              href={linkify(l.url)}
              target={l.url.startsWith("http") ? "_blank" : undefined}
              rel={l.url.startsWith("http") ? "noopener" : undefined}
              class="text-(--color-accent) hover:text-(--color-accent-strong) underline-offset-3 hover:underline"
            >
              {l.label ?? l.url} →
            </a>
          ) : null,
        )}
      </div>
    )}
  </div>
</article>
