---
import type { Publication } from "~/lib/data";
import { withBase } from "~/lib/url";

interface Props {
  pub: Publication;
  /** Extra attributes spread onto the rendered <li>. Used by /publications/
   *  to attach the data-pub / data-category / etc. filter hooks directly,
   *  since nesting <li><li> is invalid HTML and the browser auto-closes the
   *  outer one. */
  liAttrs?: Record<string, string | number | boolean | undefined>;
}
const { pub, liAttrs = {} } = Astro.props;

const detailUrl = withBase(`/publications/${pub.id}`);

const primaryUrl =
  pub.url ??
  (pub.doi ? `https://doi.org/${pub.doi}` : undefined) ??
  (pub.arxiv ? `https://arxiv.org/abs/${pub.arxiv}` : undefined) ??
  (pub.pmid ? `https://pubmed.ncbi.nlm.nih.gov/${pub.pmid}/` : undefined);

const authors = pub.authors ?? [];
const SHORT = 6;
const restCount = Math.max(0, authors.length - SHORT);

const typeLabel = pub.type === "preprint"
  ? "Preprint"
  : pub.type === "conference"
    ? "Conference"
    : pub.type === "chapter"
      ? "Chapter"
      : null;
---
<li class="py-4 border-b border-(--color-border) last:border-b-0" {...liAttrs}>
  <article>
    <div class="flex items-baseline gap-3 flex-wrap text-xs uppercase tracking-wider text-(--color-ink-faint)">
      <span>{pub.year}</span>
      {typeLabel && (
        <span class="px-1.5 py-0.5 rounded border border-(--color-border) bg-(--color-surface)/50">
          {typeLabel}
        </span>
      )}
      {pub.venue && <span class="normal-case tracking-normal italic">{pub.venue}</span>}
    </div>
    <h3 class="mt-1.5 text-(--color-ink) leading-snug">
      <a
        href={detailUrl}
        class="hover:text-(--color-accent) transition-colors"
      >
        {pub.title}
      </a>
    </h3>
    {authors.length > 0 && (
      restCount === 0 ? (
        <p class="mt-1 text-sm text-(--color-ink-muted) italic">{authors.join(", ")}</p>
      ) : (
        <p class="mt-1 text-sm text-(--color-ink-muted) italic" data-authors>
          <span data-authors-short>{authors.slice(0, SHORT).join(", ")}</span><span
            data-authors-rest
            hidden
          >, {authors.slice(SHORT).join(", ")}</span>
          <button
            type="button"
            data-authors-toggle
            data-rest-count={restCount}
            aria-expanded="false"
            class="not-italic ml-1 text-xs text-(--color-accent) hover:text-(--color-accent-strong) underline-offset-3 hover:underline"
          >+{restCount} more</button>
        </p>
      )
    )}
    <div class="mt-1.5 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs">
      <a
        href={detailUrl}
        class="inline-flex items-center gap-1 rounded-md border border-(--color-border) hover:border-(--color-accent) hover:text-(--color-accent) text-(--color-ink-muted) px-2 py-0.5 font-medium transition-colors"
      >
        Details
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </a>
      {pub.doi && (
        <a
          href={`https://doi.org/${pub.doi}`}
          target="_blank"
          rel="noopener"
          class="text-(--color-accent) hover:text-(--color-accent-strong) underline-offset-3 hover:underline"
        >
          doi
        </a>
      )}
      {pub.arxiv && (
        <a
          href={`https://arxiv.org/abs/${pub.arxiv}`}
          target="_blank"
          rel="noopener"
          class="text-(--color-accent) hover:text-(--color-accent-strong) underline-offset-3 hover:underline"
        >
          arXiv
        </a>
      )}
      {pub.pmid && (
        <a
          href={`https://pubmed.ncbi.nlm.nih.gov/${pub.pmid}/`}
          target="_blank"
          rel="noopener"
          class="text-(--color-accent) hover:text-(--color-accent-strong) underline-offset-3 hover:underline"
        >
          PubMed
        </a>
      )}
      {pub.pmcid && (
        <a
          href={`https://pmc.ncbi.nlm.nih.gov/articles/${pub.pmcid}/`}
          target="_blank"
          rel="noopener"
          class="text-(--color-accent) hover:text-(--color-accent-strong) underline-offset-3 hover:underline"
        >
          PMC
        </a>
      )}
      {pub.github && (
        <a
          href={`https://github.com/${pub.github}`}
          target="_blank"
          rel="noopener"
          class="text-(--color-accent) hover:text-(--color-accent-strong) underline-offset-3 hover:underline"
        >
          code
        </a>
      )}
    </div>
  </article>
</li>

<script>
  document.querySelectorAll<HTMLButtonElement>("[data-authors-toggle]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const root = btn.closest<HTMLElement>("[data-authors]");
      if (!root) return;
      const rest = root.querySelector<HTMLElement>("[data-authors-rest]");
      if (!rest) return;
      const expanded = btn.getAttribute("aria-expanded") === "true";
      rest.hidden = expanded;
      btn.setAttribute("aria-expanded", String(!expanded));
      btn.textContent = expanded ? `+${btn.dataset.restCount} more` : "show less";
    });
  });
</script>
