---
import type { TeamMember } from "~/lib/data";

interface Props {
  member: TeamMember;
  size?: "sm" | "md";
}
const { member, size = "sm" } = Astro.props;
const px = size === "md" ? 18 : 16;

const links: { label: string; href: string; symbol: string }[] = [];

if (member.website) links.push({ label: "Personal site", href: member.website, symbol: "globe" });
if (member.github) {
  const u = member.github.startsWith("http") ? member.github : `https://github.com/${member.github}`;
  links.push({ label: `GitHub: ${member.github}`, href: u, symbol: "github" });
}
if (member.linkedin) {
  const u = member.linkedin.startsWith("http")
    ? member.linkedin
    : `https://www.linkedin.com/in/${member.linkedin.replace(/^@/, "")}/`;
  links.push({ label: "LinkedIn", href: u, symbol: "linkedin" });
}
if (member.scholar) {
  const u = member.scholar.startsWith("http")
    ? member.scholar
    : `https://scholar.google.com/citations?user=${member.scholar}`;
  links.push({ label: "Google Scholar", href: u, symbol: "scholar" });
}
if (member.orcid) {
  const id = member.orcid.replace(/^https?:\/\/orcid\.org\//, "");
  links.push({ label: `ORCID: ${id}`, href: `https://orcid.org/${id}`, symbol: "orcid" });
}
if (member.twitter) {
  const handle = member.twitter.replace(/^@/, "").replace(/^https?:\/\/(twitter|x)\.com\//, "");
  links.push({ label: `X / Twitter: @${handle}`, href: `https://x.com/${handle}`, symbol: "twitter" });
}
if (member.bluesky) {
  const handle = member.bluesky.replace(/^@/, "").replace(/^https?:\/\/bsky\.app\/profile\//, "");
  links.push({ label: `Bluesky: ${handle}`, href: `https://bsky.app/profile/${handle}`, symbol: "bluesky" });
}
---
{links.length > 0 && (
  <ul class="mt-2 flex flex-wrap gap-1.5 text-(--color-ink-muted)">
    {links.map((l) => (
      <li>
        <a
          href={l.href}
          target="_blank"
          rel="noopener me"
          aria-label={l.label}
          title={l.label}
          class="inline-flex items-center justify-center w-7 h-7 rounded-md border border-(--color-border) hover:border-(--color-accent) hover:text-(--color-accent) transition-colors"
        >
          {l.symbol === "github" && (
            <svg width={px} height={px} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2c-3.2.7-3.87-1.54-3.87-1.54-.52-1.33-1.28-1.69-1.28-1.69-1.05-.71.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.74-1.55-2.56-.29-5.25-1.28-5.25-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.47.11-3.06 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.8 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.77.12 3.06.74.81 1.18 1.84 1.18 3.1 0 4.43-2.7 5.4-5.27 5.69.41.36.78 1.06.78 2.13v3.16c0 .31.21.66.79.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5Z"/></svg>
          )}
          {l.symbol === "linkedin" && (
            <svg width={px} height={px} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.95v5.66H9.36V9h3.41v1.56h.05c.47-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12Zm1.78 13.02H3.56V9h3.56v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0Z"/></svg>
          )}
          {l.symbol === "globe" && (
            <svg width={px} height={px} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/></svg>
          )}
          {l.symbol === "scholar" && (
            <svg width={px} height={px} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2 1 8.5 12 15l9.4-5.55V16h1.6V8.5L12 2Zm0 13.6L4.4 11v3.7c0 2.1 3.4 3.8 7.6 3.8s7.6-1.7 7.6-3.8V11L12 15.6Z"/></svg>
          )}
          {l.symbol === "orcid" && (
            <svg width={px} height={px} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.6 0 12 0ZM7.4 17.7H5.7V8h1.7v9.7Zm-.85-11a1 1 0 1 1 0-2 1 1 0 0 1 0 2Zm12.6 6.06c0 2.78-2.07 4.94-4.84 4.94H9.6V8h4.7c2.77 0 4.85 2.16 4.85 4.76Zm-1.74-.01c0-1.84-1.18-3.18-3.05-3.18h-3v6.4h3c1.67 0 3.05-1.32 3.05-3.22Z"/></svg>
          )}
          {l.symbol === "twitter" && (
            <svg width={px} height={px} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817-5.97 6.817H1.671l7.73-8.835L1.246 2.25h6.832l4.713 6.231 5.453-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z"/></svg>
          )}
          {l.symbol === "bluesky" && (
            <svg width={px} height={px} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 11c-1.5-3-6-8.7-10-9-1.3 0 .9 6.5 1.5 8.7C2 11.7.4 12.4.2 13.7c-.2 1.6 1 2.7 2 2.8 2.4.3 5.5-3.7 6.5-5.5C7.7 13 4 17 2.2 19.4c-.6.7-.7 1.7-.3 2.5.5 1 1.7 1.3 2.7 1 3-1 6-3 7.4-5.8 1.4 2.8 4.4 4.8 7.4 5.8 1 .3 2.2 0 2.7-1 .4-.8.3-1.8-.3-2.5-1.8-2.4-5.5-6.4-6.5-8.3 1 1.8 4 5.8 6.5 5.5 1-.1 2.2-1.2 2-2.8-.2-1.3-1.8-2-2.3-2C22 8.5 24.3 2 23 2c-4 .3-8.5 6-10 9Z"/></svg>
          )}
        </a>
      </li>
    ))}
  </ul>
)}
