---
import Container from "./Container.astro";
import { withBase } from "~/lib/url";

const year = new Date().getFullYear();
// Prefer COMMIT_SHA (the PR head, set by our workflow) over GITHUB_SHA, which on
// pull_request events is the synthetic merge commit and not findable in branch
// history.
const commit = (process.env.COMMIT_SHA ?? process.env.GITHUB_SHA ?? "dev").slice(0, 7);
const builtAt = new Date().toISOString().replace("T", " ").slice(0, 16) + "Z";

const funders = [
  // NIH (most active grants — primary funder for the group)
  { label: "NIH/NIDA U24 DA064429", href: "https://reporter.nih.gov/search/OsbCHzaScU6FVeHg9b-MGw/project-details/10888562" },
  { label: "NIH/NIMH U24 MH130918" },
  { label: "NIH/NIMH UM1 MH134812" },
  { label: "NIH/NIMH R24 MH117295" },
  { label: "NIH/NINDS UM1 NS132358" },
  { label: "NIH/NIBIB P41 EB019936" },
  { label: "NIH/OD OT2 OD032720" },
  // Other current sponsors
  { label: "MIT GenAI Consortium", href: "https://mitgenai.mit.edu/" },
  { label: "Schmidt Futures", href: "https://www.schmidtfutures.com/" },
  { label: "Citadel" },
  { label: "Simons Foundation", href: "https://www.simonsfoundation.org/" },
  { label: "Child Mind Institute", href: "https://childmind.org/" },
  // Philanthropy
  { label: "Lann S. Woehrle '78 and Christopher Woehrle Psychiatric Research Fund" },
  { label: "MIT Philips Award for Clinicians", href: "https://medicalresearch.mit.edu/" },
  { label: "Philanthropic support" },
];

const affiliations = [
  {
    label: "McGovern Institute for Brain Research",
    href: "https://mcgovern.mit.edu",
  },
  { label: "Massachusetts Institute of Technology", href: "https://www.mit.edu" },
  {
    label: "Dept. of Otolaryngology, HMS",
    href: "https://oto.hms.harvard.edu/",
  },
  {
    label: "Speech and Hearing Bioscience and Technology Program",
    href: "https://www.hms.harvard.edu/dms/shbt/",
  },
];
---
<footer class="mt-24 border-t border-(--color-border) bg-(--color-surface)/40">
  <Container size="wide" class="py-12">
    <div class="grid gap-10 md:grid-cols-3 text-sm">
      <div>
        <h3 class="text-(--color-ink) font-semibold tracking-tight mb-3">
          About
        </h3>
        <p class="text-(--color-ink-muted) leading-relaxed">
          We are part of:
        </p>
        <ul class="mt-2 space-y-1.5 text-(--color-ink-muted)">
          {affiliations.map((a) => (
            <li>
              <a
                href={a.href}
                class="hover:text-(--color-accent) transition-colors underline-offset-3 hover:underline"
              >
                {a.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-(--color-ink) font-semibold tracking-tight mb-3">
          Funding
        </h3>
        <ul class="flex flex-wrap gap-1.5 text-(--color-ink-muted) text-xs">
          {funders.map((f) => (
            <li>
              {f.href ? (
                <a
                  href={f.href}
                  target="_blank"
                  rel="noopener"
                  class="inline-block rounded-md border border-(--color-border) px-1.5 py-0.5 hover:border-(--color-accent) hover:text-(--color-accent) transition-colors leading-tight"
                >
                  {f.label}
                </a>
              ) : (
                <span class="inline-block rounded-md border border-(--color-border) px-1.5 py-0.5 leading-tight">{f.label}</span>
              )}
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-(--color-ink) font-semibold tracking-tight mb-3">
          Contact
        </h3>
        <address class="not-italic text-(--color-ink-muted) leading-relaxed">
          satra <span aria-hidden="true">at</span> mit <span aria-hidden="true">dot</span> edu<br />
          McGovern Institute for Brain Research<br />
          46-4033F, 43 Vassar St<br />
          Cambridge, MA 02139 USA
        </address>
        <a
          href="http://whereis.mit.edu/?go=46"
          target="_blank"
          rel="noopener"
          class="mt-2 inline-block text-(--color-accent) hover:text-(--color-accent-strong) underline-offset-3 hover:underline"
        >
          Directions →
        </a>
      </div>
    </div>
    <div
      class="mt-10 pt-6 border-t border-(--color-border) flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between text-xs text-(--color-ink-faint)"
    >
      <p>© 2019 – {year} Senseable Intelligence Group</p>
      <span class="font-mono text-[10px] opacity-70" title={`Built ${builtAt}`}>
        build {commit} · {builtAt}
      </span>
      <a
        href={withBase("/about")}
        class="hover:text-(--color-accent) transition-colors underline-offset-3 hover:underline"
      >
        About this website
      </a>
    </div>
  </Container>
</footer>
