---
import type { Publication } from "~/lib/data";
import { normalizeImage } from "~/lib/images";

interface Props {
  pub: Publication;
  variant?: "full" | "compact";
}
const { pub, variant = "full" } = Astro.props;
const image = pub.image ? normalizeImage(pub.image) : null;
const codeLink = pub["code link"];
---
{variant === "compact" ? (
  <article class="py-4 border-b border-(--color-border) last:border-b-0">
    <h3 class="font-medium text-(--color-ink) leading-snug">{pub.title}</h3>
    {pub.authors && (
      <p class="mt-1 text-sm text-(--color-ink-muted) italic">{pub.authors}</p>
    )}
    <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1 text-sm text-(--color-ink-faint)">
      {pub.date && <span>{pub.date}</span>}
      {pub.type && <span>{pub.type}</span>}
      {pub.link?.url && (
        <a
          href={pub.link.url}
          target="_blank"
          rel="noopener"
          class="text-(--color-accent) hover:text-(--color-accent-strong) underline-offset-3 hover:underline"
        >
          {pub.link.display ?? "Article"} →
        </a>
      )}
      {codeLink?.url && (
        <a
          href={codeLink.url}
          target="_blank"
          rel="noopener"
          class="text-(--color-accent) hover:text-(--color-accent-strong) underline-offset-3 hover:underline"
        >
          {codeLink.display ?? "Code"} →
        </a>
      )}
    </div>
  </article>
) : (
  <article
    class="rounded-lg border border-(--color-border) bg-(--color-canvas) p-5 hover:border-(--color-border-strong) transition-colors"
  >
    <div class="flex gap-5">
      {image && (
        <img
          src={image}
          alt={pub.title}
          loading="lazy"
          class="hidden sm:block w-28 h-28 object-cover rounded-md bg-(--color-surface) shrink-0"
        />
      )}
      <div class="min-w-0">
        <h3 class="font-serif text-lg font-semibold text-(--color-ink) leading-snug">
          {pub.title}
        </h3>
        {pub.authors && (
          <p class="mt-1 text-sm text-(--color-ink-muted) italic">{pub.authors}</p>
        )}
        {pub.description && (
          <p class="mt-3 text-sm text-(--color-ink-muted) leading-relaxed">
            {pub.description}
          </p>
        )}
        <div class="mt-3 flex flex-wrap gap-x-4 gap-y-1 text-sm">
          {pub.link?.url && (
            <a
              href={pub.link.url}
              target="_blank"
              rel="noopener"
              class="text-(--color-accent) hover:text-(--color-accent-strong) underline-offset-3 hover:underline"
            >
              {pub.link.display ?? "Article"} →
            </a>
          )}
          {codeLink?.url && (
            <a
              href={codeLink.url}
              target="_blank"
              rel="noopener"
              class="text-(--color-accent) hover:text-(--color-accent-strong) underline-offset-3 hover:underline"
            >
              {codeLink.display ?? "Code"} →
            </a>
          )}
        </div>
      </div>
    </div>
  </article>
)}
