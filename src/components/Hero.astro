---
import Container from "./Container.astro";
import { withBase } from "~/lib/url";

const slides = [
  {
    src: "/images/220505-group-lunch.webp",
    caption: "The group, May 2022",
    alt: "Group lunch, May 2022",
  },
  {
    src: "/images/external/default-36895d2a.webp",
    alt: "Figure from an eLife publication",
  },
  {
    src: "/images/external/nipype_architecture-2ac08216.webp",
    alt: "Nipype workflow architecture diagram",
  },
  {
    src: "/images/external/pnas.1608282113fig01-eabc721d.webp",
    alt: "Figure from a PNAS publication",
  },
  {
    src: "/images/external/jama-sad-treatment-prediction.webp",
    caption: "Predicting treatment response in SAD — JAMA Psychiatry",
    alt: "Figure from a JAMA Psychiatry paper on predicting treatment outcome in social anxiety disorder",
  },
];
---
<section class="relative overflow-hidden border-b border-(--color-border)">
  <div
    aria-hidden="true"
    class="absolute inset-0 -z-10 bg-gradient-to-b from-(--color-accent-soft)/60 to-(--color-canvas)"
  ></div>
  <Container size="wide" class="py-20 md:py-28">
    <div class="grid lg:grid-cols-[1.1fr_1fr] gap-12 items-center">
      <div>
        <p
          class="text-xs uppercase tracking-[0.2em] text-(--color-accent) font-medium"
        >
          Senseable Intelligence Group · MIT
        </p>
        <h1
          class="mt-4 font-serif text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.05] text-(--color-ink)"
        >
          Welcome!
        </h1>
        <p
          class="mt-6 text-lg md:text-xl text-(--color-ink-muted) leading-relaxed max-w-2xl"
        >
          Brain health is our north star — guiding our work to connect across
          scales of neuroscience, from cells to circuits to behavior. We build
          open frameworks, run extensive collaborations, and combine
          neuroimaging, speech, and machine learning to make brain and mental
          health assessments and treatments more reliable, equitable, and
          reproducible.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href={withBase("/research")}
            class="inline-flex items-center gap-2 rounded-md bg-(--color-accent) hover:bg-(--color-accent-strong) text-white px-5 py-2.5 text-sm font-medium transition-colors"
          >
            Explore our research →
          </a>
          <a
            href={withBase("/team")}
            class="inline-flex items-center gap-2 rounded-md border border-(--color-border) hover:border-(--color-border-strong) px-5 py-2.5 text-sm font-medium text-(--color-ink) transition-colors"
          >
            Meet the team
          </a>
        </div>
      </div>
      <div class="relative" data-carousel-root>
        <div
          class="aspect-[4/3] overflow-hidden rounded-xl border border-(--color-border) bg-(--color-surface) shadow-sm"
          data-carousel
        >
          {slides.map((slide, i) => (
            <figure
              data-slide={i}
              class={`absolute inset-0 transition-opacity duration-700 ${
                i === 0 ? "opacity-100" : "opacity-0"
              }`}
            >
              <img
                src={slide.src.startsWith("/") ? withBase(slide.src) : slide.src}
                alt={slide.alt}
                loading={i === 0 ? "eager" : "lazy"}
                class="w-full h-full object-contain bg-(--color-surface)"
              />
              {slide.caption && (
                <figcaption
                  class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/60 via-black/30 to-transparent text-white text-xs px-4 py-3"
                >
                  {slide.caption}
                </figcaption>
              )}
            </figure>
          ))}
        </div>
        <div class="mt-3 flex items-center justify-center gap-2">
          {slides.map((_, i) => (
            <button
              type="button"
              data-dot={i}
              aria-label={`Slide ${i + 1}`}
              class={`h-1.5 rounded-full transition-all ${
                i === 0
                  ? "w-6 bg-(--color-accent)"
                  : "w-1.5 bg-(--color-border-strong) hover:bg-(--color-ink-faint)"
              }`}
            ></button>
          ))}
        </div>
      </div>
    </div>
  </Container>
</section>

<script>
  document.querySelectorAll<HTMLElement>("[data-carousel-root]").forEach((root) => {
    const carousel = root.querySelector<HTMLElement>("[data-carousel]");
    if (!carousel) return;
    const slides = Array.from(carousel.querySelectorAll<HTMLElement>("[data-slide]"));
    const dots = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-dot]"));
    if (!slides.length) return;
    let i = 0;
    const show = (n: number) => {
      i = (n + slides.length) % slides.length;
      slides.forEach((el, idx) => {
        el.style.opacity = idx === i ? "1" : "0";
      });
      dots.forEach((el, idx) => {
        if (idx === i) {
          el.classList.remove("w-1.5", "bg-(--color-border-strong)", "hover:bg-(--color-ink-faint)");
          el.classList.add("w-6", "bg-(--color-accent)");
        } else {
          el.classList.add("w-1.5", "bg-(--color-border-strong)", "hover:bg-(--color-ink-faint)");
          el.classList.remove("w-6", "bg-(--color-accent)");
        }
      });
    };
    dots.forEach((dot, idx) => dot.addEventListener("click", () => show(idx)));
    let timer = window.setInterval(() => show(i + 1), 5500);
    carousel.addEventListener("mouseenter", () => window.clearInterval(timer));
    carousel.addEventListener("mouseleave", () => {
      timer = window.setInterval(() => show(i + 1), 5500);
    });
  });
</script>
